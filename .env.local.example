# ─── Supabase ───────────────────────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # Never expose this client-side

# ─── Cloudinary ─────────────────────────────────────────────────────────────
# Found in: Cloudinary Dashboard → Settings → API Keys
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret              # Never expose this client-side

# ─── Cron Security ──────────────────────────────────────────────────────────
# A random secret string to prevent unauthorized cron triggers.
# Generate one with: openssl rand -base64 32
CRON_SECRET=your-random-secret-here

# ─── App URL ────────────────────────────────────────────────────────────────
# Used for OAuth redirect URLs
NEXT_PUBLIC_APP_URL=http://localhost:3000
